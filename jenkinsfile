pipeline {
    agent any

    triggers { 
        githubPush() 
    }

    environment {
        DOCKER_IMAGE_NAME = 'calculator'
        GITHUB_REPO_URL = 'https://github.com/anuja-jmk/pipelined-miniproject.git'
        CONTAINER_NAME = 'calculator'
        DOCKER_USER_NAME = 'anujajose'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: "${GITHUB_REPO_URL}"
            }
        }

        stage('Cleanup Old Containers') {
            steps {
                sh '''
                echo "Cleaning old container if they exist"
                docker stop $CONTAINER_NAME || true
                docker rm -f $CONTAINER_NAME || true
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${DOCKER_USER_NAME}/${DOCKER_IMAGE_NAME}", ".")
                }
            }
        }

        stage('Run Unit Tests in Test Container') {
            steps {
                sh '''
                echo "Running unit tests in temporary container"
                docker run --name $CONTAINER_NAME ${DOCKER_USER_NAME}/${DOCKER_IMAGE_NAME} pytest
                '''
            }
        }

        stage('Remove Test Container') {
            steps {
                sh '''
                echo "Cleaning test container"
                docker stop $CONTAINER_NAME || true
                docker rm -f $CONTAINER_NAME || true
                '''
            }
        }

        stage('Push Docker Images') {
            steps {
                script {
                    docker.withRegistry('', 'DockerCred') {
                        sh "docker push ${DOCKER_USER_NAME}/${DOCKER_IMAGE_NAME}:latest"
                    }
                }
            }
        }

        stage('Run Ansible Playbook') {
            steps {
                ansiblePlaybook(
                    playbook: 'deploy.yml',
                    inventory: 'inventory'
                )
            }
        }

    }
}